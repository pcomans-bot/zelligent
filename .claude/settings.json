{
  "permissions": {
    "allow": [
      "Bash(bash test.sh:*)",
      "Bash(bash tests/harness/fixtures/*)",
      "Bash(cd /tmp/zelligent-test-repo *)",
      "Bash(zellij *)",
      "Bash(git add:*)",
      "Bash(git push:*)",
      "Bash(gh pr:*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-push-block.sh"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "chrome-devtools-mcp@chrome-devtools-plugins": true
  }
}
